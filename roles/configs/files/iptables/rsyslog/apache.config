############################################
# Firewall Logging Rules (iptables + ip6tables)
# Custom filters for firewall prefixes
############################################

# Ensure logs go to a dedicated directory
$FileOwner root
$FileGroup adm
$FileCreateMode 0640
$DirCreateMode 0750
$Umask 0022

# -------- IPv4 INVALID & Bad TCP ----------
:msg, contains, "INVALID_PKT:"       -/var/log/firewall/invalid.log
:msg, contains, "BAD_TCP_FLAG:"      -/var/log/firewall/bad-tcp.log

# -------- Anti-Spoofing Logs ----------
:msg, contains, "SPOOF_LAN_ON_WAN:"  -/var/log/firewall/spoof.log
:msg, contains, "SPOOF_MAN_ON_WAN:"  -/var/log/firewall/spoof.log
:msg, contains, "SPOOF_WLAN_ON_WAN:" -/var/log/firewall/spoof.log
:msg, contains, "SPOOF_FAIL_LAN:"    -/var/log/firewall/spoof.log
:msg, contains, "SPOOF_FAIL_MAN:"    -/var/log/firewall/spoof.log
:msg, contains, "SPOOF_FAIL_WLAN:"   -/var/log/firewall/spoof.log

# -------- ICMP Logs ----------
:msg, contains, "ICMP_PING:"         -/var/log/firewall/icmp.log

# -------- Inter-Zone Blocks ----------
:msg, contains, "MAN_BLOCK_LAN:"     -/var/log/firewall/zones.log
:msg, contains, "WLAN_BLOCK_LAN:"    -/var/log/firewall/zones.log
:msg, contains, "WLAN_BLOCK_MAN:"    -/var/log/firewall/zones.log

# -------- VPN ----------
:msg, contains, "VPN_TRAFFIC:"       -/var/log/firewall/vpn.log

# -------- Docker ----------
:msg, contains, "DOCKER_OUT:"        -/var/log/firewall/docker.log
:msg, contains, "DOCKER_IN:"         -/var/log/firewall/docker.log

# -------- Final Drops ----------
:msg, contains, "DROP_INPUT:"        -/var/log/firewall/drops.log
:msg, contains, "DROP_FORWARD:"      -/var/log/firewall/drops.log

# -------- IPv6 ----------
:msg, contains, "IPV6_INVALID:"      -/var/log/firewall/ipv6-invalid.log
:msg, contains, "IPV6_DROP_INPUT:"   -/var/log/firewall/ipv6-drop.log
:msg, contains, "IPV6_DROP_FW:"      -/var/log/firewall/ipv6-drop.log

# Stop messages from going to syslog again
:msg, contains, "INVALID_PKT:"       stop
:msg, contains, "BAD_TCP_FLAG:"      stop
:msg, contains, "SPOOF_"             stop
:msg, contains, "ICMP_PING:"         stop
:msg, contains, "MAN_BLOCK_LAN:"     stop
:msg, contains, "WLAN_BLOCK_LAN:"    stop
:msg, contains, "WLAN_BLOCK_MAN:"    stop
:msg, contains, "VPN_TRAFFIC:"       stop
:msg, contains, "DOCKER_"            stop
:msg, contains, "DROP_INPUT:"        stop
:msg, contains, "DROP_FORWARD:"      stop
:msg, contains, "IPV6_"              stop

:msg, contains, "LAN_"      -/var/log/firewall/lan.log
:msg, contains, "MAN_"      -/var/log/firewall/man.log
:msg, contains, "WLAN_"     -/var/log/firewall/wlan.log
:msg, contains, "WAN_"      -/var/log/firewall/wan.log